# =============================================================================
# IronHermes Environment Variables
# =============================================================================
# Copy to ~/.ironhermes/.env and uncomment the values you need.
# See cli-config.yaml.example for YAML-based configuration.

# =============================================================================
# LLM Providers
# =============================================================================

# --- OpenRouter (default provider) ---
# OPENROUTER_API_KEY=sk-or-...

# --- Anthropic (direct API) ---
# ANTHROPIC_API_KEY=sk-ant-...

# --- Google / Gemini ---
# GOOGLE_API_KEY=
# GEMINI_API_KEY=

# --- OpenAI ---
# OPENAI_API_KEY=sk-...

# --- Ollama (local or cloud) ---
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_API_KEY=

# --- Groq ---
# GROQ_API_KEY=gsk_...

# --- Together AI ---
# TOGETHER_API_KEY=

# --- Mistral ---
# MISTRAL_API_KEY=

# --- Perplexity ---
# PERPLEXITY_API_KEY=

# --- DeepSeek ---
# DEEPSEEK_API_KEY=

# --- Fireworks AI ---
# FIREWORKS_API_KEY=

# =============================================================================
# Tool API Keys
# =============================================================================

# --- Firecrawl (web scraping backend) ---
# FIRECRAWL_API_KEY=fc-...

# --- Exa (search) ---
# EXA_API_KEY=

# =============================================================================
# Terminal / Sandbox Configuration
# =============================================================================

# Sandbox backend: "local" (default) or "docker" (future)
# TERMINAL_BACKEND=local

# Default working directory for agent tool operations
# TERMINAL_CWD=.

# Command execution timeout in seconds (default: 30)
# TERMINAL_TIMEOUT=30

# Docker sandbox image (when TERMINAL_BACKEND=docker)
# TERMINAL_DOCKER_IMAGE=ironhermes-sandbox:latest

# Comma-separated env vars to pass through to sandbox
# TERMINAL_ENV=HOME,USER,PATH

# =============================================================================
# Code Execution (execute_code tool)
# =============================================================================

# Path to Python interpreter (default: python3)
# EXEC_PYTHON_PATH=python3

# Execution timeout in seconds (default: 300)
# EXEC_TIMEOUT_SECS=300

# =============================================================================
# IronHermes Home Directory
# =============================================================================

# Override the default data directory (default: ~/.ironhermes)
# IRONHERMES_HOME=~/.ironhermes

# =============================================================================
# Gateway -- Telegram
# =============================================================================

# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_USERS=123456789,987654321
# TELEGRAM_HOME_CHANNEL=

# =============================================================================
# Gateway -- Discord (future)
# =============================================================================

# DISCORD_BOT_TOKEN=
# DISCORD_ALLOWED_USERS=

# =============================================================================
# Gateway -- Slack (future)
# =============================================================================

# SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=

# =============================================================================
# MCP Servers (future)
# =============================================================================

# MCP_CONFIG_PATH=~/.ironhermes/mcp-servers.yaml

# =============================================================================
# Browser / Browserbase (future)
# =============================================================================

# BROWSERBASE_API_KEY=
# BROWSERBASE_PROJECT_ID=

# =============================================================================
# Debug Flags
# =============================================================================

# WEB_TOOLS_DEBUG=false
# VISION_TOOLS_DEBUG=false
# RUST_LOG=ironhermes=info
