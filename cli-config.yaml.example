# =============================================================================
# IronHermes Configuration
# =============================================================================
# Copy to ~/.ironhermes/config.yaml and customize.
# Values shown are defaults -- uncomment and change as needed.
# Environment variables in .env override matching config values.

# --- Model Configuration ---
model:
  # Default model identifier
  # default: "anthropic/claude-sonnet-4"

  # LLM provider: openrouter, anthropic, openai, ollama, google, together, mistral, groq, deepseek, fireworks
  # provider: "openrouter"

  # Override API base URL (usually not needed)
  # base_url: null

  # DEPRECATED — use providers.<name>.api_key_env instead (see "Provider Overrides" below).
  # Kept one release for backwards compat; emits a deprecation banner at startup.
  # api_key: null

  # Vision model for image analysis (null = use default model)
  # vision_model: null

  # Maximum tokens per response (null = provider default)
  # max_tokens: null

  # Model context window size (null = auto-detect from model metadata)
  # context_length: null

  # Auxiliary model role assignments (provider + optional model override)
  # roles:
  #   vision:
  #     provider: "openrouter"
  #     model: "openai/gpt-4o"
  #   compression:
  #     provider: "main"    # "main" inherits the primary provider

# --- Agent Configuration ---
agent:
  # Maximum agent loop iterations per turn (default: 90)
  # max_turns: 90

  # Context compression ratio (default: 0.5)
  # context_compression: 0.5

  # Delay between tool calls in seconds (default: 1.0)
  # tool_delay_secs: 1.0

  # Context engine: "summarizing" (default, uses LLM) or "local_prune" (heuristic)
  # context_engine: "summarizing"

  # Compression threshold as fraction of context_length (default: 0.5)
  # compression_threshold: 0.5

  # Optional system message injected into prompt (empty = omitted)
  # system_message: ""

  # Custom personality presets (name -> system prompt text)
  # personalities:
  #   pirate: "You are a helpful pirate assistant. Arr!"

# --- Terminal / Sandbox ---
terminal:
  # Sandbox backend: "local" (default) or "docker" (future)
  # backend: "local"

  # Default working directory for agent tool operations
  # "." means current directory; set to "~/.ironhermes/workspace" for isolation
  # cwd: "."

  # Command execution timeout in seconds (default: 30)
  # timeout: 30

# --- Web Tools ---
web:
  # Web scraping backend: "firecrawl" (default) or "raw"
  # backend: "firecrawl"

  # User-Agent header for HTTP requests
  # user_agent: "IronHermes/1.0 (+bot)"

  # Maximum content length in characters before truncation (default: 50000)
  # max_content_chars: 50000

  # HTTP request timeout in seconds (default: 30)
  # timeout_secs: 30

# --- Code Execution ---
exec:
  # Path to Python interpreter (default: "python3")
  # python_path: "python3"

  # Execution timeout in seconds (default: 300 = 5 minutes)
  # timeout_secs: 300

  # Maximum RPC calls per execution (default: 50)
  # max_rpc_calls: 50

  # Maximum stdout bytes before truncation (default: 50000)
  # max_output_bytes: 50000

  # Maximum stderr bytes before truncation (default: 10240)
  # max_stderr_bytes: 10240

# --- Gateway ---
gateway:
  # Context engine for gateway sessions (default: "local_prune")
  # context_engine: "local_prune"

  # Compression threshold for gateway (default: 0.85)
  # compression_threshold: 0.85

  # Platform adapters
  # The `platforms:` map is empty by default. To enable Telegram, uncomment the
  # `telegram:` block below AND provide a token (env var or `token:`).
  # platforms:
  #   telegram:
  #     # Enable Telegram gateway (required to register the platform at all)
  #     enabled: true
  #
  #     # Bot token. Prefer the TELEGRAM_BOT_TOKEN env var (in ~/.ironhermes/.env)
  #     # over inlining the secret here. If both are set, env var wins.
  #     # token: "123456:ABC-DEF..."
  #
  #     # Allowed Telegram chat IDs (integers). Empty list = deny all.
  #     # Get your chat ID by messaging @userinfobot on Telegram.
  #     whitelist: [123456789]
  #
  #     # Session inactivity timeout in hours (default: 24)
  #     # session_timeout_hours: 24
  #
  #     # Maximum concurrent agent runs (default: 8)
  #     # max_concurrent_runs: 8
  platforms: {}

# --- Cron ---
cron:
  # Wrap cron job responses with metadata (default: true)
  # wrap_response: true

# --- Memory ---
memory:
  # Memory provider: "file" (default), "sqlite", "grafeo", "duckdb"
  # provider: "file"

  # Optional write-only mirror provider (receives on_memory_write events)
  # mirror_provider: null

  # Enable/disable entire memory subsystem (default: true)
  # memory_enabled: true

  # Enable/disable USER.md profile store (default: true)
  # user_profile_enabled: true

  # Periodic memory-review nudge interval, in user turns (default: 10).
  # After this many successful agent turns, a fire-and-forget background
  # nudge asks the model to decide what's worth persisting to MEMORY.md /
  # USER.md vs. leaving in session history (searchable via session_search).
  # The nudge runs in all three surfaces (CLI run_chat, Telegram gateway,
  # embedded web UI) and uses a private memory-only ToolRegistry — it cannot
  # call session_search, web_read, execute_code, or browser tools.
  #   nudge_interval: 10   # recommended starting point
  #   nudge_interval: 3    # aggressive (more memory writes, more API cost)
  #   nudge_interval: 0    # disable the periodic nudge entirely
  # nudge_interval: 10

  # Autonomous skill-creation guidance (Phase 33, LEARN-03/04).
  # When true AND the `skill_manage` tool is registered (via the `learning`
  # toolset), the system prompt includes the "Skill Creation (Learning Loop)"
  # trigger block telling the agent when to author a new SKILL.md. The
  # `skill_manage` tool writes self-created skills under
  # $HERMES_HOME/skills/<category>/<slug>/SKILL.md with trust_tier="Self-created".
  # Set to false to keep `skill_manage` available but suppress the prompt
  # block (e.g. for child agents or restricted deployments).
  # skill_creation_guidance: true

# --- Compression ---
compression:
  # Tokens to protect at end of conversation (default: 20000)
  # protect_last_tokens: 20000

  # Token budget for tool-pair boundary shifting (default: 500)
  # tool_pair_shift_tokens: 500

  # Number of messages protected at start of conversation (default: 3)
  # protect_first_n: 3

# --- Skills ---
skills:
  # Master enable switch (default: true)
  # enabled: true

  # Additional skill scan paths (appended after defaults)
  # extra_paths: []

  # Root directory for skill credentials
  # credential_dir: null

  # Per-skill configuration values
  # config:
  #   wiki:
  #     path: "~/research"
  #     format: "markdown"

  # Skills Hub settings
  # hub:
  #   trusted_repos: []
  #   github_token_env: null
  #   extra_taps: []
  #   well_known_origins: []

# --- Subagent Delegation ---
subagent:
  # Timeout per subagent execution in seconds (default: 300)
  # timeout_secs: 300

  # Maximum concurrent subagents (default: 3)
  # max_subagents: 3

  # Maximum LLM iterations per subagent (default: 10)
  # max_iterations: 10

  # Default toolset groups for child agents
  # default_toolsets: ["terminal", "file", "web"]

  # Override model for subagents (null = use parent's model)
  # model: null

  # Override provider for subagents (null = use parent's provider)
  # provider: null

# --- Rate Limiting ---
rate_limit:
  # Maximum sustained messages per minute per user (default: 10)
  # messages_per_minute: 10

  # Maximum burst size (default: 3)
  # burst_size: 3

# --- Batch Processing ---
batch:
  # Default worker concurrency (default: 4)
  # workers: 4

  # Default max agent iterations per prompt (default: 20)
  # max_turns: 20

  # Default output directory relative to cwd (default: "batch_output")
  # output_dir: "batch_output"

# --- Security ---
security:
  # Redact secrets in logs and output (default: true)
  # redact_secrets: true

# --- Provider Overrides ---
# Per-provider configuration. This is the canonical place to wire API keys
# and override defaults. `api_key_env` references an env var name (validated
# against [A-Z][A-Z0-9_]*) — the actual secret stays in ~/.ironhermes/.env.
#
# Recommended pattern (silences the deprecation warnings for legacy env-var
# fallback and `model.api_key`):
#
# IMPORTANT: At least one provider entry with api_key_env matching model.provider
# is REQUIRED for validation to pass. Without it the setup wizard re-launches
# on every start. The actual secret stays in ~/.ironhermes/.env.
#
# Example (openrouter as default):
providers:
  openrouter:
    api_key_env: OPENROUTER_API_KEY     # secret lives in .env
    # api_mode: chat_completions          # override only if needed
    # fallback_providers: ["local-llama"] # one-shot swap on 401/403/404/429/5xx.
    #                                     # The fallback uses ITS OWN default_model
    #                                     # (the primary's model string is NOT
    #                                     # carried over), so a local server doesn't
    #                                     # need to know the primary's model name.
    # base_url: null                      # override only if needed
    # default_model: "anthropic/claude-sonnet-4"
    # disabled: false                     # set true to exclude from resolver
#   anthropic:
#     api_key_env: ANTHROPIC_API_KEY
#     api_mode: anthropic_messages
#   openai:
#     api_key_env: OPENAI_API_KEY
#     api_mode: chat_completions
#
# Legacy fields (still parsed, will warn at startup):
#   - `api_key: <literal>` under a provider — use `api_key_env` instead.
#   - `model.api_key:` at the top level — use `providers.<main>.api_key_env`.
#   - Bare `OPENROUTER_API_KEY` / `ANTHROPIC_API_KEY` / `OPENAI_API_KEY` env
#     vars without a matching `providers.<name>.api_key_env` declaration.

# --- Custom Providers ---
# User-defined OpenAI-compatible endpoints. A common use is naming a local
# Ollama / llama.cpp server here and listing it under a primary's
# `fallback_providers` so the agent falls back to it on hard failure.
# When the fallback fires it uses the `default_model` defined HERE — not the
# primary's model — so this must name a model the local server has loaded.
# custom_providers:
#   - name: "local-llama"
#     base_url: "http://localhost:11434/v1"
#     api_key: "ollama"
#     api_mode: chat_completions
#     default_model: "llama3.2:latest"

# --- Learning Loop ---
# These keys are written by the setup wizard (`apply_learning_loop_answer` in
# `ironhermes-core/src/wizard.rs`) via a raw-YAML splice. They are NOT part of
# the typed `Config` struct (serde ignores them) and survive only through the
# raw-YAML load-mutate-save path. When the learning loop is disabled,
# `skill_generation_enabled` and `skill_eval` become `false`; the other three
# keys keep the same values shown below.
# learning:
#   skill_generation_enabled: true
#   periodic_nudge_interval_seconds: 300
#   reflection_depth: "standard"
#   skill_eval: true
#   max_skills: 500

# --- Tools ---
# Mirrors `ToolsConfig::default()` in `ironhermes-core/src/config.rs`.
# Each key under `toolsets:` is a toolset name; `enabled: false` keeps all
# of that toolset's tools out of the LLM tool list entirely.
# tools:
#   toolsets:
#     memory:
#       enabled: true
#     session:
#       enabled: true
#     agent:
#       enabled: true
#     skills:
#       enabled: true
#     robotics:
#       enabled: true   # gates further on HEXAPOD_IP env var
#     learning:
#       enabled: true   # Phase 33 — autonomous skill creation (skill_manage tool)
#     web:
#       enabled: false   # opt-in required
#     code:
#       enabled: false   # opt-in required
#     browser:
#       enabled: false   # opt-in required

# --- Hooks ---
# hooks:
#   jsonl_log: true
#   webhooks: []
