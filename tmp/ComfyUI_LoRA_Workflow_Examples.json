  "troubleshooting_guide": {
    "common_issues": {
      "lora_not_loading": {
        "symptoms": ["No visible effect", "Error messages"],
        "solutions": [
          "Check file path and name",
          "Verify LoRA compatibility with base model",
          "Ensure proper file format (.safetensors or .bin)",
          "Check for corrupted files"
        ]
      },
      "excessive_lora_effect": {
        "symptoms": ["Distorted features", "Unrealistic results", "Overfitting"],
        "solutions": [
          "Reduce LoRA strengths (try 0.5-0.7 range)",
          "Remove conflicting LoRAs",
          "Adjust prompt weights",
          "Use negative prompts to counteract unwanted effects"
        ]
      },
      "memory_errors": {
        "symptoms": ["VRAM overflow", "Slow generation", "Crashes"],
        "solutions": [
          "Use --lowvram launch argument",
          "Reduce number of simultaneous LoRAs", 
          "Lower batch sizes",
          "Use model offloading settings"
        ]
      },
      "inconsistent_results": {
        "symptoms": ["Variable quality", "Unpredictable outputs"],
        "solutions": [
          "Use consistent seeds for testing",
          "Check LoRA interaction compatibility",
          "Standardize strength values",
          "Implement proper workflow organization"
        ]
      }
    },

    "debugging_workflow": {
      "step_by_step": [
        "1. Test base model without LoRAs",
        "2. Add one LoRA at a time",
        "3. Check individual LoRA effects", 
        "4. Test LoRA combinations gradually",
        "5. Document working configurations",
        "6. Use Display Any nodes for debugging"
      ]
    }
  },

