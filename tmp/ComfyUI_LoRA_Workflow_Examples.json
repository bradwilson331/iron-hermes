{
  "workflow_examples": {
    "basic_single_lora": {
      "description": "Basic single LoRA application workflow",
      "nodes": [
        {
          "type": "CheckpointLoaderSimple",
          "inputs": {"ckpt_name": "realistic_model.safetensors"}
        },
        {
          "type": "LoraLoader", 
          "inputs": {
            "model": "@CheckpointLoaderSimple.model",
            "clip": "@CheckpointLoaderSimple.clip",
            "lora_name": "character_lora.safetensors",
            "strength_model": 0.8,
            "strength_clip": 0.8
          }
        },
        {
          "type": "CLIPTextEncode",
          "inputs": {
            "text": "portrait of a woman, detailed face, high quality",
            "clip": "@LoraLoader.clip"
          }
        },
        {
          "type": "KSampler",
          "inputs": {
            "model": "@LoraLoader.model",
            "positive": "@CLIPTextEncode.conditioning"
          }
        }
      ],
      "best_practices": [
        "Start with 0.8 strength for character LoRAs",
        "Use high-quality realistic checkpoint",
        "Include LoRA trigger words in prompt"
      ]
    },
    
    "multiple_lora_chain": {
      "description": "Multiple LoRA chaining for complex effects",
      "nodes": [
        {
          "type": "CheckpointLoaderSimple",
          "inputs": {"ckpt_name": "sdxl_realistic.safetensors"}
        },
        {
          "type": "LoraLoader",
          "name": "Character LoRA",
          "inputs": {
            "model": "@CheckpointLoaderSimple.model",
            "clip": "@CheckpointLoaderSimple.clip", 
            "lora_name": "character_main.safetensors",
            "strength_model": 0.9,
            "strength_clip": 0.9
          }
        },
        {
          "type": "LoraLoader",
          "name": "Style LoRA", 
          "inputs": {
            "model": "@Character_LoRA.model",
            "clip": "@Character_LoRA.clip",
            "lora_name": "photography_style.safetensors", 
            "strength_model": 0.6,
            "strength_clip": 0.6
          }
        },
        {
          "type": "LoraLoader",
          "name": "Detail LoRA",
          "inputs": {
            "model": "@Style_LoRA.model",
            "clip": "@Style_LoRA.clip",
            "lora_name": "skin_detail.safetensors",
            "strength_model": 0.4,
            "strength_clip": 0.3
          }
        }
      ],
      "strength_guidelines": {
        "primary_character": "0.8-1.0",
        "style_loras": "0.5-0.7", 
        "detail_loras": "0.3-0.5",
        "concept_loras": "0.4-0.6"
      }
    },

    "power_lora_loader_workflow": {
      "description": "Using rgthree Power Lora Loader for efficient management",
      "custom_nodes_required": ["rgthree-comfy"],
      "nodes": [
        {
          "type": "CheckpointLoaderSimple",
          "inputs": {"ckpt_name": "realistic_model.safetensors"}
        },
        {
          "type": "Power Lora Loader",
          "inputs": {
            "model": "@CheckpointLoaderSimple.model",
            "clip": "@CheckpointLoaderSimple.clip",
            "loras": [
              {"name": "character_woman.safetensors", "strength": 0.8, "enabled": true},
              {"name": "photography_style.safetensors", "strength": 0.6, "enabled": true},
              {"name": "detailed_skin.safetensors", "strength": 0.4, "enabled": true},
              {"name": "alternative_style.safetensors", "strength": 0.7, "enabled": false}
            ]
          }
        }
      ],
      "features": [
        "Multiple LoRAs in single node",
        "Individual enable/disable toggles",
        "Easy strength adjustment",
        "Visual organization"
      ]
    },

    "context_switching_workflow": {
      "description": "Dynamic LoRA switching using Context Switch",
      "custom_nodes_required": ["rgthree-comfy"],
      "nodes": [
        {
          "type": "CheckpointLoaderSimple"
        },
        {
          "type": "Context",
          "name": "Portrait Context",
          "inputs": {
            "model": "@Portrait_LoRAs.model",
            "clip": "@Portrait_LoRAs.clip"
          }
        },
        {
          "type": "Context", 
          "name": "Action Context",
          "inputs": {
            "model": "@Action_LoRAs.model",
            "clip": "@Action_LoRAs.clip"
          }
        },
        {
          "type": "Context Switch",
          "inputs": {
            "ctx_01": "@Portrait_Context.context",
            "ctx_02": "@Action_Context.context"
          }
        },
        {
          "type": "Fast Muter",
          "connected_nodes": ["Portrait Context", "Action Context"],
          "purpose": "Toggle between different LoRA combinations"
        }
      ],
      "workflow_benefits": [
        "Easy A/B testing of LoRA combinations",
        "Clean workflow organization", 
        "Performance optimization through muting",
        "Rapid iteration capabilities"
      ]
    },

    "realistic_character_consistency": {
      "description": "Workflow for consistent realistic character generation",
      "focus": "Character consistency across multiple generations",
      "nodes": [
        {
          "type": "CheckpointLoaderSimple",
          "inputs": {"ckpt_name": "realistic_vision_v6.safetensors"}
        },
        {
          "type": "LoraLoader",
          "name": "Main Character",
          "inputs": {
            "lora_name": "character_face.safetensors",
            "strength_model": 0.85,
            "strength_clip": 0.85
          }
        },
        {
          "type": "LoraLoader", 
          "name": "Photorealism",
          "inputs": {
            "lora_name": "realistic_photography.safetensors",
            "strength_model": 0.6,
            "strength_clip": 0.5
          }
        },
        {
          "type": "LoraLoader",
          "name": "Detail Enhancement", 
          "inputs": {
            "lora_name": "skin_detail_v2.safetensors",
            "strength_model": 0.35,
            "strength_clip": 0.25
          }
        },
        {
          "type": "rgthree Seed",
          "inputs": {
            "seed": -1,
            "control": "randomize"
          }
        }
      ],
      "prompting_strategy": {
        "positive": "portrait of [character_trigger], detailed skin texture, professional photography, natural lighting, high resolution",
        "negative": "cartoon, anime, painting, fake, artificial, low quality, blurry",
        "techniques": [
          "Use specific character trigger words",
          "Emphasize photorealistic qualities",
          "Include lighting and quality descriptors"
        ]
      }
    },

    "style_blending_workflow": {
      "description": "Advanced style blending with multiple artistic LoRAs",
      "complexity": "Advanced",
      "nodes": [
        {
          "type": "CheckpointLoaderSimple"
        },
        {
          "type": "LoraLoader",
          "name": "Base Character",
          "strength_guidelines": "Keep high for consistency (0.8-0.9)"
        },
        {
          "type": "LoraLoader",
          "name": "Primary Style",
          "strength_guidelines": "Medium strength (0.5-0.7)"
        },
        {
          "type": "LoraLoader", 
          "name": "Secondary Style",
          "strength_guidelines": "Lower strength (0.3-0.5)"
        },
        {
          "type": "LoraLoader",
          "name": "Detail Style",
          "strength_guidelines": "Subtle application (0.2-0.4)"
        }
      ],
      "blending_strategies": {
        "complementary_styles": {
          "description": "Styles that enhance each other",
          "example": "Realistic + Cinematic + Detailed",
          "strength_ratio": "0.8 : 0.6 : 0.3"
        },
        "contrasting_styles": {
          "description": "Mixing different artistic approaches", 
          "example": "Photorealistic + Artistic + Painterly",
          "strength_ratio": "0.9 : 0.4 : 0.2"
        }
      }
    },

    "conditional_lora_application": {
      "description": "Conditional LoRA application based on prompts or switches",
      "custom_nodes_required": ["rgthree-comfy", "efficiency-nodes"],
      "workflow_structure": {
        "input_analysis": {
          "type": "Text Analysis", 
          "purpose": "Determine which LoRAs to apply based on prompt content"
        },
        "conditional_switches": {
          "type": "Any Switch",
          "purpose": "Route to appropriate LoRA combinations"
        },
        "lora_branches": [
          {
            "condition": "portrait_detected",
            "loras": ["character_face.safetensors", "portrait_lighting.safetensors"]
          },
          {
            "condition": "full_body_detected", 
            "loras": ["character_full.safetensors", "pose_enhancement.safetensors"]
          },
          {
            "condition": "artistic_style_requested",
            "loras": ["artistic_style.safetensors", "creative_lighting.safetensors"]
          }
        ]
      }
    },

    "batch_variation_workflow": {
      "description": "Generate multiple variations with different LoRA combinations",
      "purpose": "A/B testing and variation generation",
      "structure": {
        "base_setup": {
          "checkpoint": "Same for all variations",
          "base_prompt": "Consistent core prompt",
          "resolution": "Consistent dimensions"
        },
        "variation_branches": [
          {
            "variation_1": {
              "loras": ["style_a.safetensors:0.7", "detail_a.safetensors:0.4"],
              "prompt_addition": ", cinematic lighting"
            },
            "variation_2": {
              "loras": ["style_b.safetensors:0.6", "detail_b.safetensors:0.5"], 
              "prompt_addition": ", natural lighting"
            },
            "variation_3": {
              "loras": ["style_c.safetensors:0.8", "detail_a.safetensors:0.3"],
              "prompt_addition": ", dramatic lighting"
            }
          }
        ],
        "batch_processing": {
          "queue_all": "Process all variations in sequence",
          "compare_results": "Use Image Comparer node for side-by-side analysis"
        }
      }
    }
  },

